NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/tripai
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
# Comma-separated allowed browser origins (required)
FRONTEND_ORIGIN=http://localhost:5173
# Optional extra origins (e.g. preview deployments)
# CORS_EXTRA_ORIGINS=https://trip-frontend0.vercel.app

# Production (Render) example:
# NODE_ENV=production
# PORT=10000
# FRONTEND_ORIGIN=https://trip-frontend0.vercel.app
LOG_LEVEL=info
BCRYPT_SALT_ROUNDS=12
OPENWEATHER_API_KEY=your-openweather-api-key

# Razorpay (test mode)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ADMIN_EMAIL=mukarramuddin09@gmail.com
